# =====================================================================
# PRODUCTION ENVIRONMENT TEMPLATE
# Copy to .env and replace ALL secrets before `docker compose up`.
# Generate strong secrets with: openssl rand -hex 32
# NEVER commit the resulting .env file.
# Production API startup is fail-closed until prototype API seeding is made safe.
# =====================================================================

# --- Database ---
POSTGRES_DB=gamepanel
POSTGRES_USER=gamepanel
POSTGRES_PASSWORD=
DATABASE_URL=

# --- Redis ---
REDIS_ADDR=redis:6379

# --- Panel URL (publicly reachable base URL for email links) ---
PANEL_URL=https://panel.example.com

# --- API ---
API_ADDR=:8080
API_AUTH_SECRET=
APP_ENV=production

# --- Node token format: <token_id>.<secret> ---
DAEMON_NODE_TOKEN=

# --- Daemon ---
DAEMON_ADDR=:9090
DAEMON_SFTP_ADDR=:2022
DAEMON_DATA_DIR=/srv/game-panel/servers
DAEMON_NODE_ID=
DAEMON_ALLOW_MOCK_RUNTIME=false
PANEL_API_URL=http://api:8080/api/v1


# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# --- Backup adapter: "local" or "s3" ---
BACKUP_ADAPTER=local
# S3_BUCKET=my-game-panel-backups
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_PREFIX=panel/
# S3_USE_PATH_STYLE=true

