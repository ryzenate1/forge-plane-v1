# GamePanel local development defaults

APP_ENV=development

# API
API_ADDR=:8080
API_AUTH_SECRET=dev-api-secret
API_DEMO_MODE=false
DATABASE_URL=postgres://gamepanel:gamepanel@localhost:5432/gamepanel?sslmode=disable
REDIS_ADDR=localhost:6379
MIGRATIONS_DIR=forge/api/migrations
DAEMON_NODE_TOKEN=devnodetoken0001.dev-node-token

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_SFTP_HOST=127.0.0.1
NEXT_PUBLIC_SFTP_PORT=2222
NEXT_PUBLIC_SFTP_USER=game

# Daemon
DAEMON_ADDR=:9090
DAEMON_DATA_DIR=/srv/game-panel/servers
DAEMON_NODE_ID=22222222-2222-2222-2222-222222222222
PANEL_API_URL=http://localhost:8080/api/v1
DAEMON_ALLOW_MOCK_RUNTIME=false

# Encryption at Rest (Required when DATABASE_URL is set)
# Generate a 32-byte key, then encode as strict base64 or 64 hex characters.
# For local development, this default key can be used.
FORGE_MASTER_KEY=YWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWE=
FORGE_MASTER_KEY_ID=primary
# Development-only escape hatch: allows starting with a random ephemeral key if true
FORGE_ALLOW_EPHEMERAL_MASTER_KEY=false

